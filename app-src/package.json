{
  "name": "docker-swarm-dashboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:esm": "node --experimental-vm-modules --no-warnings node_modules/jest/bin/jest.js --config jest-esm.config.mjs",
    "test:coverage": "jest --coverage --runInBand",
    "start-api-mock": "node --enable-source-maps mock/api/api-mock.mjs 3001",
    "start-dev-server": "vite --port 3000",
    "open-browser": "open http://localhost:3000#base=\"http%3A%2F%2Flocalhost%3A3001%2F\"",
    "start": "concurrently \"yarn run start-api-mock\" \"yarn run start-dev-server\" \"sleep 2 && yarn run open-browser\"",
    "start:servers": "concurrently \"yarn run start-api-mock\" \"yarn run start-dev-server\"",
    "format": "prettier --write src/**/*.js",
    "format:check": "prettier --check src/**/*.js",
    "postinstall": "node download-files.js",
    "lint": "eslint src",
    "lint:css": "stylelint src/**/*.css",
    "build": "vite build",
    "cy:open": "yarn cypress open",
    "cy:run": "yarn cypress run",
    "cy:run:all-res": "yarn cypress run --env viewportWidth=3840,viewportHeight=2160 && yarn cypress run --env viewportWidth=1920,viewportHeight=1080",
    "cy:spec": "yarn cypress run --spec",
    "dev:cy:run": "xvfb-run yarn cypress run",
    "test:e2e": "node scripts/run-e2e.js"
  },
  "files": [
    {
      "name": "docker.png",
      "url": "http://getcarina.github.io/jupyterhub-tutorial/slides/img/docker-swarm.png"
    }
  ],
  "engines": {
    "node": ">=26.0.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-syntax-flow": "^7.29.7",
    "@babel/plugin-transform-react-jsx": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-react": "^7.29.7",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@popperjs/core": "^2.11.8",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.2",
    "apexcharts": "^5.13.0",
    "axios": "^1.16.1",
    "babel-jest": "^30.4.1",
    "bootstrap": "^5.3.8",
    "concurrently": "^10.0.0",
    "cors": "^2.8.6",
    "cypress": "^15.16.0",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-alias": "^1.1.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "jotai": "^2.20.0",
    "jotai-location": "^0.6.2",
    "json-server": "1.0.0-beta.15",
    "prettier": "^3.8.3",
    "prop-types": "^15.8.1",
    "react": "^19.2.6",
    "react-apexcharts": "^2.1.0",
    "react-bootstrap": "^2.10.10",
    "react-dom": "^19.2.6",
    "react-transition-group": "^4.4.5",
    "react-use-websocket": "^4.13.0",
    "start-server-and-test": "^3.0.5",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "vite": "^8.0.14",
    "wait-on": "^9.0.10",
    "whatwg-fetch": "^3.6.20"
  },
  "dependencies": {
    "jotai-family": "^1.0.2"
  }
}
